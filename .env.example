# YieldScope — Variáveis de ambiente
# Copie este arquivo para .env e preencha as chaves

# ============================================================
# Whale Tracker — APIs de blockchain (opcionais)
# Sem chaves, o tracker exibe dados demonstrativos
# ============================================================

# Helius (Solana) — https://helius.dev
VITE_HELIUS_API_KEY=

# Alchemy (Ethereum, Base, Arbitrum, Polygon) — https://alchemy.com
VITE_ALCHEMY_API_KEY=

# Etherscan-compatible (Ethereum) — https://etherscan.io/apis
VITE_ETHERSCAN_API_KEY=

# Covalent/Moralis (multi-chain) — opcionais
VITE_COVALENT_API_KEY=

# ============================================================
# Firebase (opcional — para auth e watchlist)
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=

# ============================================================
# PRO — Configuração do token de acesso
# ============================================================
VITE_PRO_TOKEN_SYMBOL=yldSOL
VITE_PRO_TOKEN_MIN_AMOUNT=10
